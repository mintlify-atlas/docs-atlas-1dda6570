  "keyFeatures": [
    "Fast XML importing with casting to classes and Eloquent models",
    "XML exporting from nested arrays with automatic tag generation",
    "Export Laravel Blade views directly to XML format",
    "Built-in transformers for data manipulation",
    "Optimization options for camelCase and underscore naming conventions",
    "Support for attributes and nested XML structures"
  ],
  "publicApiSurface": [
    "XML::import(string $path, bool $raw = false)",
    "XML::export(array $data)",
    "XML::exportView(string $viewName, array $data = [])",
    "XMLCollection::cast(string $key)",
    "XMLCollection::transform(string $key)",
    "XMLCollection::expect(string $key)",
    "XMLCollection::optimize(string $type)",
    "XMLCollection::get()",
    "XMLCollection::raw()",
    "XMLBuilder::version(string $version)",
    "XMLBuilder::encoding(string $encoding)",
    "XMLBuilder::rootTag(string $name)",
    "XMLBuilder::itemName(string $name)",
    "ArrayExporter::toString()",
    "ArrayExporter::toFile(string $path)",
    "ArrayExporter::usePrettyOutput()",
    "ViewExporter::toString()",
    "ViewExporter::toFile(string $path)"
  ]
