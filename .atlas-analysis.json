{
  "projectType": "sdk-library",
  "projectName": "Laravel XML",
  "projectDescription": "A Laravel package for easily importing and exporting XML data with casting, transformers, and view support",
  "theme": "palm",
  "primaryColor": "#FF2D20",
  "lightColor": "#FF6B59",
  "darkColor": "#C91E0E",
  "navigation": {
    "groups": [
